# Local development
# For real device testing, use your computer LAN IP (e.g. http://192.168.1.10:8000)
# Android emulator: http://10.0.2.2:8000
# iOS simulator: http://127.0.0.1:8000

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-or-publishable-key
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8000
EXPO_PUBLIC_EXPO_PROJECT_ID=e30d200f-efea-4c11-985b-67ed201c07a0
EXPO_PUBLIC_BACKEND_USER_ID=1

# Backward compatibility for older code paths. Keep same value as API_BASE_URL.
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:8000
